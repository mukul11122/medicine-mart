{
  "name": "project",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun --watch run server.tsx",
    "dev:client": "vite",
    "build": "vite build",
    "start": "bun run server.tsx",
    "generate": "bun ./node_modules/@shogo-ai/sdk/bin/cli.mjs generate",
    "db:generate": "bun x --bun prisma generate",
    "db:migrate:dev": "bun x --bun prisma migrate dev",
    "db:migrate:deploy": "bun x --bun prisma migrate deploy",
    "db:push": "bun x --bun prisma db push",
    "db:reset": "bun x --bun prisma db push --force-reset --accept-data-loss",
    "db:studio": "bun x --bun prisma studio"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.3.0",
    "@shogo-ai/sdk": "^1.10.0",
    "@types/nodemailer": "^8.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "firebase": "^12.16.0",
    "hono": "^4.0.0",
    "lucide-react": "^0.563.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@prisma/internals": "^7.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^8.2.0",
    "postcss": "^8.5.6",
    "prisma": "^7.3.0",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.0.0"
  }
}
